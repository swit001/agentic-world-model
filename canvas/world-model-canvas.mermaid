%%{init: {"theme": "neutral"}}%%
flowchart TD
    subgraph L1["Layer 1 В· World Definition"]
        direction LR
        M["**M**\nMission & Scope\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ngoal В· owner В· boundaries"]
        E["**E**\nEntities & Ontology\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nid В· relationships"]
        Sigma["**ОЈ**\nState Space & SSOT Schema\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nstates В· initial В· terminal"]
    end

    subgraph L2["Layer 2 В· World Dynamics"]
        direction LR
        S["**S**\nCurrent States\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ninstance В· state В· as_of"]
        T["**T**\nTransitions\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nfrom В· to В· trigger В· guards"]
        C["**C**\nConstraints & Policies\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nglobal В· per_entity"]
    end

    subgraph L3["Layer 3 В· World Operation"]
        direction LR
        O["**O**\nObservations & Grounding\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nsources В· context_schema"]
        V["**V**\nVerdicts & Outcome Contracts\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nALLOW В· DENY В· ESCALATE"]
        H["**H**\nHuman Approvals & Escalation\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ntriggers В· routes В· SLA"]
        A["**A**\nAudit Trail & Learning\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nevents В· retention В· feedback"]
    end

    %% World Definition flow
    M --> E
    E --> Sigma

    %% Definition feeds Dynamics
    Sigma -->|"valid states"| S
    Sigma -->|"state constraints"| T
    E -->|"entity type"| T
    C -->|"policy gates"| T

    %% Dynamics feeds Operation
    O -->|"grounds context"| S
    T -->|"transition attempt"| V

    %% Operation routing
    V -->|"ESCALATE"| H
    V -->|"ALLOW / DENY"| A
    H -->|"approval decision"| A
    H -->|"approved"| T

    %% Styling
    classDef layer1 fill:#dbeafe,stroke:#3b82f6,color:#1e3a8a
    classDef layer2 fill:#dcfce7,stroke:#22c55e,color:#14532d
    classDef layer3 fill:#fef9c3,stroke:#eab308,color:#713f12

    class M,E,Sigma layer1
    class S,T,C layer2
    class O,V,H,A layer3
